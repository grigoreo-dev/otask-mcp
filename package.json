{
  "name": "otask-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for O!task API — tasks and authentication",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "otask-mcp": "dist/index.js",
    "otask-proxy": "dist/http-server.js"
  },
  "scripts": {
    "start": "bun run dist/index.js",
    "start:http": "bun run dist/http-server.js",
    "dev": "bun --watch src/index.ts",
    "dev:http": "bun --watch src/http-server.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
