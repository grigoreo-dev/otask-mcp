{
  "name": "otask-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for O!task API — tasks and authentication",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "otask-mcp": "dist/index.js",
    "otask-proxy": "dist/http-server.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http-server.ts",
    "build": "node ./node_modules/typescript/bin/tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    }
  }
}
