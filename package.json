{
  "name": "@grigoreo-dev/otask-mcp",
  "version": "1.2.0",
  "description": "MCP server for O!task API — stdio locally, Streamable HTTP for n8n",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "otask-mcp": "dist/index.js",
    "otask-mcp-http": "dist/mcp-http.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grigoreo-dev/otask-mcp.git"
  },
  "license": "MIT",
  "scripts": {
    "start": "bun run dist/index.js",
    "start:http": "bun run dist/mcp-http.js",
    "dev": "bun --watch src/index.ts",
    "dev:http": "bun --watch src/mcp-http.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "bun test",
    "docs:parse": "bun run scripts/parse-docs.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
