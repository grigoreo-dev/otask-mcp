{
  "name": "@grigoreo-dev/otask-mcp",
  "version": "1.5.0",
  "description": "MCP server for O!task API — stdio locally, Streamable HTTP for n8n",
  "type": "module",
  "main": "packages/stdio/dist/index.js",
  "bin": {
    "otask-mcp": "packages/stdio/dist/index.js",
    "otask-mcp-http": "packages/http-node/dist/mcp-http.js"
  },
  "files": [
    "packages/core/dist",
    "packages/stdio/dist",
    "packages/http-node/dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grigoreo-dev/otask-mcp.git"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "bun run packages/stdio/dist/index.js",
    "start:http": "bun run packages/http-node/dist/mcp-http.js",
    "dev": "bun run --filter @grigoreo-dev/otask-mcp-core build && bun --watch packages/stdio/src/index.ts",
    "dev:http": "bun run --filter @grigoreo-dev/otask-mcp-core build && bun --watch packages/http-node/src/mcp-http.ts",
    "build": "bun run --filter @grigoreo-dev/otask-mcp-core build && bun run --filter @grigoreo-dev/otask-mcp-stdio build && bun run --filter @grigoreo-dev/otask-mcp-http build",
    "clean": "rm -rf packages/core/dist packages/stdio/dist packages/http-node/dist",
    "test": "bun test",
    "docs:parse": "bun run scripts/parse-docs.ts",
    "lint": "biome check .",
    "format": "biome check --write .",
    "worker:kv": "bunx wrangler kv namespace create OAUTH_KV --config packages/worker/wrangler.toml",
    "deploy:worker": "bun run build && bunx wrangler deploy --config packages/worker/wrangler.toml"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "24",
    "typescript": "^5.8.3"
  }
}
